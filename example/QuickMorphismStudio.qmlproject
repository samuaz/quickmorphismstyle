import QmlProject 1.3

Project {
    mainFile: "quickmorphismexample/Demo.qml"
    
    QmlFiles {
        directory: "."
    }
    
    QmlFiles {
        directory: "quickmorphismexample"
    }
    
    QmlFiles {
        directory: "quickmorphismexample/build/_deps/quickmorphism-src/QuickMorphism"
    }
    
    JavaScriptFiles {
        directory: "."
    }
    
    JavaScriptFiles {
        directory: "quickmorphismexample" 
    }
    
    Files {
        filter: "qmldir"
        directory: "quickmorphismexample/build/_deps/quickmorphism-src/QuickMorphism"
    }
    
    Files {
        filter: "*.conf"
        files: ["quickmorphismexample/qtquickcontrols2.conf"]
    }
    
    Files {
        filter: "*.ttf;*.otf"
        directory: "quickmorphismexample/build/_deps/quickmorphism-src/QuickMorphism/assets"
    }
    
    importPaths: [
        "quickmorphismexample/build/_deps/quickmorphism-src/QuickMorphism",
        "quickmorphismexample/build/QuickMorphism",
        "quickmorphismexample",
        "quickmorphismexample/build"
    ]
    
    Environment {
        QT_QUICK_CONTROLS_CONF: "quickmorphismexample/qtquickcontrols2.conf"
    }
    
    qt6Project: true
    qdsVersion: "4.6"
}